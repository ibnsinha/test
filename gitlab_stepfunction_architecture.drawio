<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="GitLab Automation Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- User -->
        <mxCell id="2" value="User / Trigger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Step Function -->
        <mxCell id="3" value="AWS Step Functions&#xa;(Orchestrator)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="220" y="200" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- Lambda 1 -->
        <mxCell id="4" value="Lambda 1&#xa;Validate Input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="450" y="120" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Lambda 2 -->
        <mxCell id="5" value="Lambda 2&#xa;Create Project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="450" y="300" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Secrets Manager -->
        <mxCell id="6" value="AWS Secrets Manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="650" y="300" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- GitLab -->
        <mxCell id="7" value="GitLab API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="850" y="300" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="8" style="endArrow=block;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="9" style="endArrow=block;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="10" style="endArrow=block;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="11" style="endArrow=block;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="12" style="endArrow=block;" edge="1" parent="1" source="5" target="7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
